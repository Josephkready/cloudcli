# CloudCLI UI Environment Configuration
# Only includes variables that are actually used in the code
#
# TIP: Run 'cloudcli status' to see where this file should be located
#      and to view your current configuration.
#
# Available CLI commands:
#   claude-code-ui    - Start the server (default)
#   cloudcli start    - Start the server
#   cloudcli status   - Show configuration and data locations
#   cloudcli help     - Show help information
#   cloudcli version  - Show version information

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Backend server port (Express API + WebSocket server)
#API server
SERVER_PORT=3001
#Frontend port
VITE_PORT=5173

# Host/IP to bind servers to (default: 0.0.0.0 for all interfaces)
# Use 127.0.0.1 to restrict to localhost only
HOST=0.0.0.0

# Uncomment the following line if you have a custom claude cli path other than the default "claude"
# CLAUDE_CLI_PATH=claude

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================

# Path to the authentication database file
# This is where user credentials, API keys, and tokens are stored.
#
# To use a custom location:
# DATABASE_PATH=/path/to/your/custom/auth.db
#
# Claude Code context window size (maximum tokens per session)
VITE_CONTEXT_WINDOW=160000
CONTEXT_WINDOW=160000

# =============================================================================
# AUTHENTICATION
# =============================================================================

# Disable the login/setup screen for single-user, self-hosted installs.
# When set to 'true', the app skips all login and JWT checks and runs as a
# single default user (auto-created on first start). This ONLY removes login —
# it does not change workspace paths, the WebSocket URL, or platform behavior.
# Leave unset (or 'false') to keep the normal username/password login.
#
# Read once at startup, so after changing it you must BOTH rebuild the frontend
# (VITE_ vars are inlined at build time) AND restart the server process.
#
# One-way caveat: the auto-created default user has no usable password. Once
# this has run with the flag on, turning it back off leaves you unable to log
# in (registration is blocked while any user exists). To re-enable login later,
# delete the auto-created user row (or the auth database) first, then unset this.
# VITE_AUTH_DISABLED=true

# =============================================================================
# PROJECT DISCOVERY
# =============================================================================

# Colon-separated globs of project paths to exclude from auto-discovery.
# Sessions whose recorded cwd matches any pattern are skipped during the
# provider session sync, so transient worktrees never clutter the sidebar.
# Set to empty (CLOUDCLI_EXCLUDED_PROJECT_PATHS=) to disable all exclusions.
# Glob syntax: `**` matches any chars including `/`; `*` matches any chars
# except `/`; `?` matches one char except `/`. Everything else is literal.
# Default: /tmp/**:**/worktrees/**:**/.dante-sync-clobbered/**
# CLOUDCLI_EXCLUDED_PROJECT_PATHS=/tmp/**:**/worktrees/**

# =============================================================================
# REVERSE PROXY HOSTING
# =============================================================================

# React Router basename injected into index.html as `window.__ROUTER_BASENAME__`.
# Set this when serving the SPA behind a reverse-proxy path prefix (for example
# https://example.com/cloudcli/) so React Router knows its mount point and
# client-side navigation does not unmount the app. Must start with a slash and
# match the proxy prefix exactly, with no trailing slash. Leave unset (or empty)
# for normal root-path hosting — that path is fully backwards-compatible.
# Example: ROUTER_BASENAME=/cloudcli
# ROUTER_BASENAME=

# =============================================================================
# SELF-UPDATE
# =============================================================================

# Disable the in-app update action (POST /api/system/update, the Version Upgrade
# modal's button). When set to 'true' the endpoint returns 403 instead of running
# an update. Leave unset (or 'false') to keep the update button working — that is
# the default and matches the normal npm-install and git-clone setups.
#
# Set this when something OTHER than this app owns the code on disk: configuration
# management, an image rebuild, or a system package manager. The update command is
# chosen from whether the app root is a git checkout, so a checkout that an external
# tool reconciles would get `git checkout main && git pull` run underneath it — which
# races that tool, and does not rebuild the frontend either, leaving the served client
# stale against the server. Declining the update outright is the correct answer there.
#
# Read once at startup, so restart the server after changing it. Unlike VITE_AUTH_DISABLED
# this is a server-side flag only — no frontend rebuild is needed.
# SELF_UPDATE_DISABLED=true

# =============================================================================
# AI SESSION TITLES (local LM)
# =============================================================================

# Rewrite the long "first-prompt" session titles into short sidebar labels using
# a local Ollama model. A background worker periodically finds raw, long titles
# and replaces them; manually-renamed titles and already-shortened ones are left
# untouched, and the sidebar updates live. Opt-in and OFF by default because it
# needs a local Ollama running with the chosen model pulled. Server-side only —
# no frontend rebuild, but restart the server after changing these.
# CLOUDCLI_AI_TITLES_ENABLED=true

# Ollama base URL (default: http://localhost:11434).
# CLOUDCLI_AI_TITLES_OLLAMA_URL=http://localhost:11434

# Model tag to use — must already be pulled (`ollama pull <model>`).
# A small, fast model is plenty for this; default: llama3.1:8b.
# CLOUDCLI_AI_TITLES_MODEL=llama3.1:8b

# Worker cadence and batch size. Kept gentle so a first-time backfill is a slow
# drip rather than a burst. Defaults: tick every 5000ms, 5 titles per tick.
# CLOUDCLI_AI_TITLES_INTERVAL_MS=5000
# CLOUDCLI_AI_TITLES_BATCH=5

# Only rewrite titles longer than this many characters (default: 60), so short
# titles that already read well are never touched.
# CLOUDCLI_AI_TITLES_MIN_LEN=60

# =============================================================================
# VOICE INPUT / OUTPUT (STT + TTS proxy)
# =============================================================================

# The in-chat microphone and the Voice settings tab proxy speech-to-text and
# text-to-speech through server/voice-proxy.js to an OpenAI-compatible audio
# backend (its /audio/transcriptions and /audio/speech endpoints). The feature
# is DARK until VOICE_API_BASE_URL is set — with it unset the proxy has no
# upstream to call, so the mic button does nothing. Server-side only (read on
# each request), so restart the server after changing these; no frontend rebuild.

# Base URL of the OpenAI-compatible audio backend (a trailing slash is trimmed).
# Set this to enable voice. Example: https://api.openai.com/v1
# VOICE_API_BASE_URL=

# Bearer key sent to that backend (leave blank if it needs no auth).
# VOICE_API_KEY=

# Model names to request. Defaults target OpenAI's audio API; override to match
# your backend. STT default: whisper-1. TTS default: tts-1. TTS voice: alloy.
# VOICE_STT_MODEL=whisper-1
# VOICE_TTS_MODEL=tts-1
# VOICE_TTS_VOICE=alloy

# Per-request timeout in milliseconds before the proxy aborts a slow backend
# (default: 300000 = 5 minutes).
# VOICE_TIMEOUT_MS=300000

